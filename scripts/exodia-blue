#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}════════════════════════════════════════${NC}"
echo -e "${YELLOW}🔵 EXODIA OS — Mode Blue Team (analyse defensive)${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
echo ""

if [ -z "$1" ]; then
    echo -e "${RED}[!] Usage: exodia-blue <fichier_a_analyser>${NC}"
    echo "   Exemple: exodia-blue /bin/ls"
    exit 1
fi

FILE="$1"

if [ ! -f "$FILE" ]; then
    echo -e "${RED}[!] Fichier non trouve : $FILE${NC}"
    exit 1
fi

echo -e "${GREEN}[+] Analyse du fichier : $FILE${NC}"
echo ""

# 1. Type de fichier
echo -e "${YELLOW}[1] Type de fichier :${NC}"
file "$FILE"
echo ""

# 2. Taille et permissions
echo -e "${YELLOW}[2] Informations generales :${NC}"
ls -la "$FILE"
echo ""

# 3. Chaînes suspectes (basique)
echo -e "${YELLOW}[3] Recherche de chaines potentiellement malveillantes :${NC}"
strings "$FILE" 2>/dev/null | grep -iE "meterpreter|reverse|shell|cmd|powershell|wscript|cscript|http|https|tcp|udp|socket|exec|system" | head -10 || echo "   Aucune chaine suspecte trouvee"
echo ""

# 4. Empreinte SHA256
echo -e "${YELLOW}[4] Empreinte SHA256 :${NC}"
sha256sum "$FILE"
echo ""

# 5. Vérification ELF basique (si c'est un exécutable Linux)
if file "$FILE" | grep -q "ELF"; then
    echo -e "${YELLOW}[5] Analyse ELF :${NC}"
    readelf -h "$FILE" 2>/dev/null | head -5 || echo "   readelf non disponible"
    echo ""
fi

# 6. Détection de sections suspectes
echo -e "${YELLOW}[6] Sections potentiellement dangereuses :${NC}"
if command -v objdump &> /dev/null; then
    objdump -x "$FILE" 2>/dev/null | grep -iE "write|exec|stack" | head -5 || echo "   Aucune section suspecte"
else
    echo "   objdump non disponible"
fi
echo ""

echo -e "${GREEN}✅ Analyse terminee.${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
