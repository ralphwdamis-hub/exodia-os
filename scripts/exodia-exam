#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SCORE=0
TOTAL=5

echo -e "${BLUE}════════════════════════════════════════${NC}"
echo -e "${YELLOW}📝 EXODIA OS — Mode Examen${NC}"
echo -e "${BLUE}════════════════════════════════════════${NC}"
echo ""

# Question 1
echo -e "${YELLOW}[1/$TOTAL]${NC} Quel payload utiliseriez-vous pour un reverse shell Windows Meterpreter ?"
echo "   a) windows/shell_reverse_tcp"
echo "   b) windows/meterpreter/reverse_tcp"
echo "   c) linux/x86/shell_reverse_tcp"
read -p "Votre réponse (a/b/c) : " q1
if [[ "$q1" == "b" ]]; then
    echo -e "${GREEN}✅ Correct${NC}"
    ((SCORE++))
else
    echo -e "${RED}❌ Faux. La bonne réponse était b) windows/meterpreter/reverse_tcp${NC}"
fi
echo ""

# Question 2
echo -e "${YELLOW}[2/$TOTAL]${NC} Quelle option msfvenom permet de définir l'IP de l'attaquant ?"
echo "   a) RPORT"
echo "   b) LHOST"
echo "   c) LPORT"
read -p "Votre réponse (a/b/c) : " q2
if [[ "$q2" == "b" ]]; then
    echo -e "${GREEN}✅ Correct${NC}"
    ((SCORE++))
else
    echo -e "${RED}❌ Faux. La bonne réponse était b) LHOST${NC}"
fi
echo ""

# Question 3
echo -e "${YELLOW}[3/$TOTAL]${NC} Avant de générer un payload, quelle est l'obligation légale ?"
echo "   a) Aucune, c'est légal"
echo "   b) Autorisation écrite du propriétaire du système cible"
echo "   c) Déclaration à la CNIL"
read -p "Votre réponse (a/b/c) : " q3
if [[ "$q3" == "b" ]]; then
    echo -e "${GREEN}✅ Correct${NC}"
    ((SCORE++))
else
    echo -e "${RED}❌ Faux. La bonne réponse était b) Autorisation écrite${NC}"
fi
echo ""

# Question 4
echo -e "${YELLOW}[4/$TOTAL]${NC} Quel format permet de générer un exécutable Windows ?"
echo "   a) elf"
echo "   b) exe"
echo "   c) python"
read -p "Votre réponse (a/b/c) : " q4
if [[ "$q4" == "b" ]]; then
    echo -e "${GREEN}✅ Correct${NC}"
    ((SCORE++))
else
    echo -e "${RED}❌ Faux. La bonne réponse était b) exe${NC}"
fi
echo ""

# Question 5
echo -e "${YELLOW}[5/$TOTAL]${NC} Que fait l'option -e x86/shikata_ga_nai ?"
echo "   a) Compresse le payload"
echo "   b) Encode le payload pour éviter la détection"
echo "   c) Change le port d'écoute"
read -p "Votre réponse (a/b/c) : " q5
if [[ "$q5" == "b" ]]; then
    echo -e "${GREEN}✅ Correct${NC}"
    ((SCORE++))
else
    echo -e "${RED}❌ Faux. La bonne réponse était b) Encode le payload${NC}"
fi
echo ""

# Résultat final
PERCENT=$((SCORE * 100 / TOTAL))
echo -e "${BLUE}════════════════════════════════════════${NC}"
if [[ $SCORE -eq $TOTAL ]]; then
    echo -e "${GREEN}🏆 Score : $SCORE/$TOTAL ($PERCENT%) — Parfait !${NC}"
elif [[ $SCORE -ge 3 ]]; then
    echo -e "${YELLOW}📘 Score : $SCORE/$TOTAL ($PERCENT%) — Passable, relisez la documentation.${NC}"
else
    echo -e "${RED}❌ Score : $SCORE/$TOTAL ($PERCENT%) — Échec. Revoir les bases de msfvenom.${NC}"
fi
echo -e "${BLUE}════════════════════════════════════════${NC}"
